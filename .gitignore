# Firebase CLI / emulator debris (repo root — the app has its own .gitignore)
firebase-debug.log
firebase-debug.*.log
ui-debug.log
.firebase/
firestore-debug.log

# CodeGraph local index (machine-local sqlite DB; each machine runs `codegraph init` once — session-rules §1)
.codegraph/

# UI/UX Pro Max skill corpus (machine-local, like .codegraph/; each machine runs `uipro init -a claude` once).
# 143 vendored third-party files; `uipro init` cannot pin a version, so committing buys no real reproducibility —
# everything binding lives in docs/adr/025 instead (ADR-025 D1/D9). Only the `ui-ux-pro-max` skill may be invoked
# in this repo; the other six installed skills are forbidden here (ADR-025 D9). `.claude/settings.json` stays tracked.
.claude/skills/

# Golden mismatch artifacts (LocalFileComparator writes these beside the test on failure)
**/failures/

# Stray tool caches at repo root (packages live in functions/ and app/)
node_modules/

# Fastlane runtime artifacts — regenerated on every real lane run; metadata/ stays tracked (ADR-021 D6)
fastlane/report.xml
fastlane/Preview.html
fastlane/test_output/
