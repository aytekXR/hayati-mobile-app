rules_version = '2';

// M2.1 surface (docs/architecture.md §3/§8): least privilege, deny-by-default.
// Every allow below is proven by the emulator rules suite in
// functions/test/emulator/firestore-rules.test.ts, including mutation tests
// that show the suite goes red if a guard here is weakened. Collections not
// matched (questions, coach_sessions) stay denied until the milestone that
// introduces them ships rules WITH tests; subscriptions has a block since M4.1
// and coachUsage since M5.1 (ADR-016). M6.2 (ADR-019) adds two server-owned
// freezes on the users update rule (notificationPrivacy, coupleEnded) and a
// profile-exists guard on soloAnswers writes; the transient deletions/{uid}
// cursor stays denied by the catch-all. No client delete is ever loosened —
// the M6.2 KVKK/PDPL cascade deletes run entirely on the admin SDK.
service cloud.firestore {
  match /databases/{database}/documents {
    function isSelf(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read: if isSelf(uid);
      // createdAt is create-once and server-stamped: the client transaction
      // sends FieldValue.serverTimestamp() on first write (M1.2,
      // FirestoreProfileRepository.saveProfile), which rules see as
      // request.time. coupleId is authorization-meaningful — it is the key that
      // grants access to couples/{coupleId} via memberUids — and is written
      // ONLY by the M2.3 join Function (admin SDK), so a client may never
      // introduce it at create. Since M6.2 (ADR-019) coupleEnded (the partner-
      // notification tombstone) and notificationPrivacy (the discreet override)
      // are server-owned too, and since S023 (ADR-023) consent (the KVKK/PDPL
      // special-category consent record: version + server acceptedAt + ageAttested,
      // written ONLY by the recordConsent callable via the admin SDK) joins them —
      // and, like coupleId, each freeze must span BOTH create AND update: the
      // update freeze below is worthless if a client can simply mint the field on
      // a fresh (or post-deletion re-created) self-doc. So a client may never
      // introduce ANY of these server-owned fields at create.
      allow create: if isSelf(uid)
        && request.resource.data.createdAt == request.time
        && !('coupleId' in request.resource.data)
        && !('coupleEnded' in request.resource.data)
        && !('notificationPrivacy' in request.resource.data)
        && !('consent' in request.resource.data);
      // Updates may never move createdAt, nor set/change/delete coupleId: a
      // client must not pair (or re-pair) itself by writing the field the join
      // Function owns. Since M6.2 (ADR-019) notificationPrivacy (the discreet
      // override) and coupleEnded (the partner-notification tombstone) are frozen
      // the same way — both are server-owned (the updateNotificationPrivacy
      // callable and the deleteAccount cascade write them via the admin SDK), so a
      // client may neither mint, change, nor clear either. Since S023 (ADR-023)
      // consent (the special-category consent record) is frozen the same way — its
      // sole writer is the recordConsent callable via the admin SDK. merge:true
      // writes that omit these fields pass (request.resource.data is the post-merge
      // document); get(...,null) compares the field or its absence on both sides
      // symmetrically.
      allow update: if isSelf(uid)
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.get('coupleId', null) == resource.data.get('coupleId', null)
        && request.resource.data.get('notificationPrivacy', null) == resource.data.get('notificationPrivacy', null)
        && request.resource.data.get('coupleEnded', null) == resource.data.get('coupleEnded', null)
        && request.resource.data.get('consent', null) == resource.data.get('consent', null);
      // Hard delete is the M6.2 KVKK/PDPL cascade Function's job (admin SDK,
      // bypasses rules); clients never delete profile documents (ADR-019).
      allow delete: if false;

      // M2.4 solo mode: the user's own daily solo reflections
      // (soloAnswers/{yyyymmdd}, docs/architecture.md §3). Self-only both
      // ways. The document surface is frozen to exactly the app's write
      // shape: hasOnly guards junk fields, answeredAt must be the server
      // stamp (== request.time, same discipline as createdAt above) so a
      // client clock can never forge the answer time, and text is bounded
      // non-empty (2000 mirrors soloAnswerMaxLength in solo_answer.dart —
      // the entry field hard-caps there, so this bound is defense-in-depth).
      // Same-day overwrites are deliberate (the answer stays editable all
      // day); client delete is denied — removal belongs to the M6.2 KVKK/PDPL
      // cascade (ADR-019). Since M6.2 the write also requires the owner's profile
      // to EXIST (the exists() guard): a just-deleted account's still-valid token
      // must not re-create an orphan soloAnswer under a swept users doc (the
      // deleted-user token-window, direct-write surface — ADR-019 D2/INVITE-1).
      // Since S023 (ADR-023 D4a) the write also requires the writer to have a
      // consent record — the special-category KVKK/PDPL precondition on the
      // reflective corpus. This bound is presence-only, version-blind: rules
      // cannot read the version constants; the app gate owns version currency
      // (ADR-023 D4a). (hasConsent subsumes the exists() guard for the
      // profile-missing case; exists() stays as the ADR-019 invariant.)
      match /soloAnswers/{dayKey} {
        allow read: if isSelf(uid);
        allow create, update: if isSelf(uid)
          && exists(/databases/$(database)/documents/users/$(uid))
          && request.resource.data.keys().hasOnly(['questionId', 'text', 'answeredAt'])
          && request.resource.data.questionId is string
          && request.resource.data.questionId.size() > 0
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('consent', null) != null
          && request.resource.data.answeredAt == request.time;
        allow delete: if false;
      }
    }

    // Member-only skeleton (M2.1). Couple documents are CREATED only by the
    // M2.3 transactional-join Function (admin SDK, bypasses rules), so client
    // create/delete stay denied (the M6.2 deleteAccount cascade performs the
    // delete via the admin SDK — ADR-019). Members may read and update, but memberUids
    // is frozen — membership changes are a Function-only operation. Since
    // M3.3 timezone and createdAt are frozen too: the stored timezone is
    // dayKey-load-bearing on BOTH sides (the rollover buckets by it, the app
    // computes the couple dayKey from it — ADR-011), so a member rewriting it
    // to junk would brick the couple's daily loop; createdAt keeps the same
    // server-stamp discipline as users. Since M3.4 (ADR-012) streak is frozen
    // too, in the symmetric-absence form: the field does not exist until the
    // first mutual day and is written ONLY by the answerReveal trigger (admin
    // SDK, bypasses rules), so a client may never introduce, change, or delete
    // it — get('streak', null) compares the field or its absence on both sides.
    // Zone changes move behind a future settings Function, like membership changes.
    match /couples/{coupleId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.memberUids;
      allow update: if request.auth != null
        && request.auth.uid in resource.data.memberUids
        && request.resource.data.memberUids == resource.data.memberUids
        && request.resource.data.timezone == resource.data.timezone
        && request.resource.data.get('streak', null) == resource.data.get('streak', null)
        && request.resource.data.createdAt == resource.data.createdAt;
      allow create, delete: if false;

      // M3.2 daily rollover (ADR-011): days/{yyyymmdd} carries question/
      // assignment metadata ONLY (questionId, packId, packVersion,
      // assignedAt), written exclusively by the questionRollover Function
      // (admin SDK, bypasses rules) — every client write is denied. Reads are
      // member-only via the parent couple's memberUids (resource.data here is
      // the day doc, so membership needs the get(); an orphaned day doc under
      // a deleted couple fails closed because get() finds nothing). Answers
      // are NOT embedded on this doc: rules are document-granular and an
      // embedded partner answer would leak pre-reveal — they live in the
      // reveal-gated per-user subcollection below (M3.3, architecture.md §3).
      match /days/{dayKey} {
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.memberUids;
        allow write: if false; // days: function-only (admin SDK)

        // M3.3 mutual reveal (architecture.md §3): one answer doc per member
        // uid. The write surface mirrors soloAnswers (hasOnly + bounded
        // non-empty text + answeredAt == request.time) plus a questionId pin
        // to the parent day doc — the pin's get() also fails closed when the
        // day doc is absent, so answers only attach to an assigned day and
        // only for its assigned question. Reads are member-only AND
        // reveal-gated: the partner's answer becomes readable ONLY once the
        // requester's own answer doc exists (exists() on the sibling path —
        // THE M3 invariant, enforced server-side, not just UI). A whole-
        // collection list flips the same way (the exists() branch is
        // document-independent): denied pre-answer, allowed post-reveal.
        // Writes are full-replace by contract: the app repository set()s all
        // three fields — a merge patching text alone fails the answeredAt
        // stamp check by construction. Edits stay open while the partner
        // hasn't answered (typo window, mirrors solo same-day editability)
        // and freeze once both answers exist: rewriting after reading the
        // partner would defeat commit-before-see, and a frozen answeredAt
        // keeps M3.4 thread/streak ordering stable. Delete is denied — the
        // reveal gate is one-way (no answer→read→retract); removal belongs
        // to the M6 KVKK/PDPL cascade. There is deliberately NO pre-answer
        // "partner has answered" signal: an existence oracle would leak
        // through uniform denial. A nudge feature needs a Function-written
        // flag or push, never a loosened read rule.
        match /answers/{authorUid} {
          function memberUids() {
            return get(/databases/$(database)/documents/couples/$(coupleId)).data.memberUids;
          }
          function hasAnswered(uid) {
            return exists(/databases/$(database)/documents/couples/$(coupleId)/days/$(dayKey)/answers/$(uid));
          }
          // S023 (ADR-023 D4a): the writer must carry a consent record before any
          // special-category reflective content lands. Presence-only, version-blind:
          // rules cannot read the version constants; the app gate owns version
          // currency (ADR-023 D4a). The full-parity claim is deliberately NOT made.
          function hasConsent() {
            return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('consent', null) != null;
          }
          function answerSurfaceOk() {
            return request.resource.data.keys().hasOnly(['questionId', 'text', 'answeredAt'])
              && request.resource.data.questionId is string
              && request.resource.data.questionId == get(/databases/$(database)/documents/couples/$(coupleId)/days/$(dayKey)).data.questionId
              && request.resource.data.text is string
              && request.resource.data.text.size() > 0
              && request.resource.data.text.size() <= 2000
              && request.resource.data.answeredAt == request.time;
          }
          allow read: if request.auth != null
            && request.auth.uid in memberUids()
            && (request.auth.uid == authorUid || hasAnswered(request.auth.uid));
          allow create: if isSelf(authorUid)
            && request.auth.uid in memberUids()
            && answerSurfaceOk()
            && hasConsent();
          allow update: if isSelf(authorUid)
            && request.auth.uid in memberUids()
            && !(hasAnswered(memberUids()[0]) && hasAnswered(memberUids()[1]))
            && answerSurfaceOk()
            && hasConsent();
          allow delete: if false; // answers: reveal gate is one-way (M6 cascade deletes)
        }
      }
    }

    // M4.1 (ADR-013): subscriptions/{coupleId} is the couple's entitlement
    // mirror — RevenueCat webhook events projected onto one couple-scoped doc
    // so a single purchase entitles both partners and expiry downgrades both
    // (architecture.md §3, §4). The revenueCatWebhook Function is the SOLE
    // writer via the admin SDK (which bypasses rules), so EVERY client write is
    // denied — create/update/delete alike. Reads are member-only via the parent
    // couple's memberUids (the doc id IS the coupleId, the M3.2 days pattern);
    // an orphaned mirror doc under a deleted couple fails closed because the
    // membership get() finds nothing. Delete belongs to the M6 KVKK/PDPL
    // cascade Function, never a client.
    match /subscriptions/{coupleId} {
      allow read: if request.auth != null
        && request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.memberUids;
      allow write: if false; // subscriptions: function-only (revenueCatWebhook, admin SDK)
    }

    // M5.1 (ADR-016 Decision 7): coachUsage/{coupleId} carries the couple's
    // coach cap counters — the coachProxy Function is the SOLE writer via the
    // admin SDK, so EVERY client write is denied. The parent doc holds the
    // couple-shared MONTHLY bucket and is member-read via the parent couple's
    // memberUids (the M3.2 days pattern; an orphaned counter under a deleted
    // couple fails closed because the membership get() finds nothing). The
    // per-user DAILY lane is split into a subcollection precisely so a partner
    // can NEVER read the other's coach-usage frequency (the violence lexicon
    // exists because domestic violence is in scope): daily/{uid} is SELF-read
    // only. Resets are lazy (applied by the next coachProxy transaction), so a
    // client watching these docs at a period boundary sees the stale stored
    // count until the next call — M5.2 prefers the response's `remaining` hint.
    match /coachUsage/{coupleId} {
      allow read: if request.auth != null
        && request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.memberUids;
      allow write: if false; // coachUsage: function-only (coachProxy, admin SDK)

      match /daily/{uid} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false; // coachUsage daily lanes: function-only
      }
    }

    // Invites are function-write-only AND function-read-only: createInvite
    // (M2.1) writes them with the admin SDK, and the invitee-facing preview is
    // the zero-auth rate-limited Function endpoint (M2.2) — never a direct
    // client read, so codes can't be enumerated or inspected past what the
    // preview chooses to expose. Explicit match kept even though the
    // deny-by-default catch-all would cover it: this is a documented invariant
    // (architecture.md §3), not an accident of fallthrough.
    match /invites/{code} {
      allow read, write: if false;
    }

    // deletions/{uid} is a transient, client-invisible progress cursor written
    // and removed by the M6.2 deleteAccount cascade (admin SDK, bypasses rules);
    // like every unmatched collection it is denied to clients by this catch-all
    // (ADR-019 Decision 2). No client match block exists or should.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
